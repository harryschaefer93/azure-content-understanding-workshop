@page "/analyze"
@using CU_TestHarness.Models
@using CU_TestHarness.Services
@using CU_TestHarness.Components.Shared
@using Microsoft.Extensions.Options
@inject ContentUnderstandingService CuService
@inject IOptions<ContentUnderstandingOptions> Options
@inject ModelProfileState ProfileState
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Analyze — CU Test Harness</PageTitle>

<div class="container">
    <h1>Content Understanding Test Harness</h1>
    <div class="model-banner">
        <strong>Model:</strong> @ProfileState.ActiveProfile.DisplayName
        @if (ProfileState.ActiveProfile.DataResidencyGuaranteed)
        { <span class="badge-residency">🔒 Region-Guaranteed</span> }
        else
        { <span class="badge-global">🌐 Global</span> }
    </div>
    <p class="subtitle">Upload a file and analyze it with Azure AI Content Understanding.</p>

    <div class="upload-section">
        <FileUploadArea Accept=".pdf,.jpg,.jpeg,.png,.tiff,.tif,.bmp,.docx,.xlsx,.pptx,.mp3,.mp4,.wav,.webm"
                        Hint="@($"PDF, images, Office docs, audio, video — up to {Options.Value.MaxFileSizeMB} MB")"
                        OnFilesSelected="OnFileSelected">
            @if (_selectedFile is not null)
            {
                <span class="file-name">@_selectedFile.Name (@FormatSize(_selectedFile.Size))</span>
            }
        </FileUploadArea>

        <div class="controls">
            <AnalyzerSelect SelectedId="@_selectedAnalyzerId"
                            OnAnalyzerChanged="id => _selectedAnalyzerId = id"
                            ShowCustomToggle="true" />

            <button class="btn-analyze" @onclick="RunAnalysis" disabled="@(_selectedFile is null || _isAnalyzing)">
                @if (_isAnalyzing)
                {
                    <span class="spinner"></span> <span>Analyzing…</span>
                }
                else
                {
                    <span>Analyze</span>
                }
            </button>
        </div>
    </div>

    @if (_result is not null)
    {
        <div class="@(_showViewer ? "split-layout" : "")">
            @if (_showViewer)
            {
                <div class="split-layout-viewer">
                    <CU_TestHarness.Components.Shared.DocumentViewer @ref="_docViewer"
                        FileBytes="_cachedFileBytes"
                        ContentType="@(_selectedFile?.ContentType ?? "")"
                        Fields="_result.Fields"
                        Pages="_result.Pages"
                        HighlightedFieldName="@_highlightedField"
                        OnFieldClicked="OnViewerFieldClicked" />
                </div>
            }
            <div class="@(_showViewer ? "split-layout-results" : "")">
        <div class="results-section">
            <div class="result-header">
                <h2>Results</h2>
                @if (_result.Fields.Count > 0)
                {
                    <span class="field-count-badge">@_result.Fields.Count fields</span>
                }
                <span class="status @_result.Status.ToLowerInvariant()">@_result.Status</span>
                @if (_result.Duration.HasValue)
                {
                    <span class="duration">@_result.Duration.Value.TotalSeconds.ToString("F1")s</span>
                }
            </div>

            @if (_result.Cost is not null)
            {
                <CostCard Cost="_result.Cost" />
            }

            @if (_result.ErrorMessage is not null)
            {
                <div class="error-box">
                    <pre>@_result.ErrorMessage</pre>
                </div>
            }
            else
            {
                <ResultsTabs Fields="_result.Fields"
                             RawJson="@_result.RawJson"
                             Markdown="@_result.Markdown"
                             ShowFieldType="true"
                             HighlightedFieldName="@_highlightedField"
                             OnFieldClicked="HandleFieldClicked"
                             FieldsEmptyMessage="No structured fields returned. Try a domain-specific analyzer (e.g. prebuilt-invoice) or a custom analyzer with a field schema." />
            }
        </div>
    }

    @* ── UC4: Natural Language Query ── *@
    @if (_result is not null && _result.Status == "Succeeded" && _cachedFileBytes is not null)
    {
        <div class="nl-query-section">
            <h3>Ask a Question (UC4)</h3>
            <p style="font-size:0.82rem;color:var(--text-muted);margin:0 0 0.5rem;">
                Ask a natural-language question about this document. CU will create a temporary <code>generate</code>-method field to answer it.
            </p>
            <div class="nl-query-input">
                <input type="text" @bind="_nlQuestion" @bind:event="oninput"
                       placeholder="e.g. What are the key obligations of the borrower?"
                       @onkeydown="NlKeyDown" />
                <button class="btn-analyze" @onclick="RunNlQuery"
                        disabled="@(string.IsNullOrWhiteSpace(_nlQuestion) || _nlQuerying)">
                    @if (_nlQuerying) { <span class="spinner"></span> } Ask
                </button>
            </div>
            @if (_nlAnswer is not null)
            {
                <div class="nl-query-answer">
                    <strong>Answer:</strong>
                    <p>@_nlAnswer</p>
                </div>
            }
            @if (_nlError is not null)
            {
                <div class="error-box"><pre>@_nlError</pre></div>
            }
        </div>
    }
            </div>@* close inner wrapper *@
        </div>@* close split-layout *@
    }
</div>

@code {
    private IBrowserFile? _selectedFile;
    private string _selectedAnalyzerId = "";
    private bool _isAnalyzing;
    private AnalysisViewModel? _result;
    private byte[]? _cachedFileBytes;
    private string? _highlightedField;
    private CU_TestHarness.Components.Shared.DocumentViewer? _docViewer;

    // NL Query (UC4)
    private string _nlQuestion = "";
    private string? _nlAnswer;
    private string? _nlError;
    private bool _nlQuerying;

    private bool _showViewer => _result is not null && _cachedFileBytes is not null &&
        (_selectedFile?.ContentType?.Contains("pdf") == true ||
         _selectedFile?.ContentType?.StartsWith("image/") == true);

    private async Task HandleFieldClicked(string fieldName)
    {
        _highlightedField = _highlightedField == fieldName ? null : fieldName;

        // Auto-navigate to the page containing this field's bounding region
        if (_highlightedField is not null && _docViewer is not null && _result is not null)
        {
            var field = _result.Fields.FirstOrDefault(f => f.Name == fieldName);
            var firstRegion = field?.BoundingRegions?.FirstOrDefault();
            if (firstRegion is not null)
            {
                await _docViewer.NavigateToPageAsync(firstRegion.PageNumber);
            }
        }
    }

    private async Task OnViewerFieldClicked(string fieldName)
    {
        _highlightedField = fieldName;
        StateHasChanged();
        await JS.InvokeVoidAsync("harnessInterop.scrollToFieldRow", fieldName);
    }

    protected override void OnInitialized()
    {
        _selectedAnalyzerId = Options.Value.DefaultAnalyzerId;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _result = null;
        _cachedFileBytes = null;
        _nlAnswer = null;
        _nlError = null;
    }

    private async Task RunAnalysis()
    {
        if (_selectedFile is null || string.IsNullOrWhiteSpace(_selectedAnalyzerId))
            return;

        _isAnalyzing = true;
        _result = null;
        StateHasChanged();

        try
        {
            var maxSize = Options.Value.MaxFileSizeMB * 1024L * 1024L;
            await using var stream = _selectedFile.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _cachedFileBytes = ms.ToArray();
            ms.Position = 0;

            _result = await CuService.AnalyzeFileAsync(
                _selectedAnalyzerId,
                ms,
                _selectedFile.Name,
                _selectedFile.ContentType);
        }
        catch (Exception ex)
        {
            _result = new AnalysisViewModel
            {
                AnalyzerId = _selectedAnalyzerId,
                FileName = _selectedFile.Name,
                Status = "Failed",
                ErrorMessage = ex.Message
            };
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private async Task NlKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_nlQuestion) && !_nlQuerying)
            await RunNlQuery();
    }

    private async Task RunNlQuery()
    {
        if (string.IsNullOrWhiteSpace(_nlQuestion) || _cachedFileBytes is null || _selectedFile is null) return;

        _nlQuerying = true;
        _nlAnswer = null;
        _nlError = null;
        StateHasChanged();

        var tempId = $"nlq{Guid.NewGuid():N}"[..32]; // max 32 chars, must start with letter
        try
        {
            // Build a minimal analyzer with one "generate" field for the question
            var safeQuestion = _nlQuestion.Replace("\"", "'").Replace("\n", " ").Replace("\r", "");
            var profile = ProfileState.ActiveProfile;
            var analyzerJson = $$"""
            {
                "analyzerId": "{{tempId}}",
                "baseAnalyzerId": "prebuilt-document",
                "models": {
                    "completion": "{{profile.CompletionModelName}}",
                    "embedding": "{{profile.EmbeddingModelName}}"
                },
                "fieldSchema": {
                    "fields": {
                        "Answer": {
                            "type": "string",
                            "method": "generate",
                            "description": "{{safeQuestion}}"
                        }
                    }
                }
            }
            """;

            var (created, createErr) = await CuService.CreateOrUpdateAnalyzerAsync(analyzerJson, allowReplace: true);
            if (!created)
            {
                _nlError = $"Failed to create temp analyzer: {createErr}";
                return;
            }

            // New analyzers need a moment to provision; retry on ScenarioNotReady
            AnalysisViewModel? result = null;
            for (int attempt = 0; attempt < 5; attempt++)
            {
                if (attempt > 0) await Task.Delay(3000);
                using var ms = new MemoryStream(_cachedFileBytes);
                result = await CuService.AnalyzeFileAsync(tempId, ms, _selectedFile.Name, _selectedFile.ContentType);
                if (result.Status == "Succeeded" || result.ErrorMessage?.Contains("ScenarioNotReady") != true)
                    break;
            }

            if (result!.Status == "Succeeded")
            {
                var answerField = result.Fields.FirstOrDefault(f =>
                    string.Equals(f.Name, "Answer", StringComparison.OrdinalIgnoreCase));
                _nlAnswer = answerField?.Value ?? "No answer returned.";
            }
            else
            {
                _nlError = result.ErrorMessage ?? "Analysis failed.";
            }
        }
        catch (Exception ex)
        {
            _nlError = ex.Message;
        }
        finally
        {
            // Clean up temp analyzer (best-effort)
            _ = CuService.DeleteAnalyzerAsync(tempId);
            _nlQuerying = false;
        }
    }
}
