@page "/feedback"
@using CU_TestHarness.Models
@using CU_TestHarness.Services
@using CU_TestHarness.Components.Shared
@inject ContentUnderstandingService CuService
@rendermode InteractiveServer

<PageTitle>Corrective Feedback — CU Test Harness</PageTitle>

<div class="container analyzers-container">
    <h1>UC6 — Corrective Feedback</h1>
    <p class="subtitle">
        Select an analyzer, refine its field descriptions, save, then re-analyze a test document to verify the improvement.
        This is the feedback loop: edit → save → re-run → check.
    </p>

    <div class="analyzers-layout">
        <AnalyzerListPanel @ref="_listPanel" SelectedId="@_selectedId" OnAnalyzerSelected="SelectAnalyzer" ShowDelete="false" />

        <!-- Edit Panel -->
        <div class="analyzer-detail-panel">
            @if (_selectedId is not null)
            {
                <div class="panel-header">
                    <h2>@_selectedId</h2>
                    <div class="detail-actions">
                        @if (!_selectedId.StartsWith("prebuilt-"))
                        {
                            @if (_isEditing)
                            {
                                <button class="btn-small btn-save" @onclick="SaveEdit" disabled="@_isSaving">
                                    @if (_isSaving) { <span class="spinner"></span> } Save
                                </button>
                                <button class="btn-small btn-cancel" @onclick="CancelEdit">Cancel</button>
                            }
                            else
                            {
                                <button class="btn-small" @onclick="StartEdit">Edit Descriptions</button>
                            }
                        }
                    </div>
                </div>

                @if (_isLoadingDef)
                {
                    <p class="no-data"><span class="spinner dark"></span> Loading definition…</p>
                }
                else if (_isEditing)
                {
                    <textarea class="schema-editor" @bind="_editJson" rows="20"></textarea>
                }
                else
                {
                    <pre class="json-output">@(_selectedDefinition ?? "Unable to load definition.")</pre>
                }

                @if (_message is not null)
                {
                    <div class="@(_isError ? "error-box" : "success-box")">
                        <pre>@_message</pre>
                    </div>
                }
            }
            else
            {
                <p class="no-data">Select a custom analyzer from the list, then edit its field descriptions.</p>
            }
        </div>
    </div>

    <!-- Re-Analyze Section -->
    @if (_selectedId is not null && !_selectedId.StartsWith("prebuilt-"))
    {
        <div class="upload-section" style="margin-top:1.5rem;">
            <h2 style="margin:0 0 0.5rem;font-size:1.1rem;">Re-Analyze Test Document</h2>
            <p style="font-size:0.82rem;color:var(--text-muted);margin:0 0 0.75rem;">
                Upload a document to run through <strong>@_selectedId</strong>. After editing field descriptions above, re-analyze to verify improvement.
            </p>

            <div class="upload-area @(_isDragOver ? "drag-over" : "")"
                 @ondragenter="@(() => _isDragOver = true)"
                 @ondragleave="@(() => _isDragOver = false)"
                 @ondragover:preventDefault>
                <InputFile OnChange="OnTestFileSelected" accept=".pdf,.jpg,.jpeg,.png,.tiff,.tif,.bmp,.docx,.xlsx,.pptx" />
                <div class="upload-prompt">
                    @if (_testFile is not null)
                    {
                        <span class="file-name">@_testFile.Name</span>
                    }
                    else
                    {
                        <span>Drag &amp; drop a file here, or <strong>click to browse</strong></span>
                    }
                </div>
            </div>

            <button class="btn-analyze" style="margin-top:0.75rem;" @onclick="RunReAnalysis" disabled="@(_testFile is null || _isAnalyzing)">
                @if (_isAnalyzing) { <span class="spinner"></span> <span>Analyzing…</span> } else { <span>Re-Analyze</span> }
            </button>

            @if (_analysisResult is not null)
            {
                <div style="margin-top:1rem;">
                    <div class="result-header">
                        <h2>Results</h2>
                        <span class="status @(_analysisResult.Status.ToLower())">@_analysisResult.Status</span>
                        @if (_analysisResult.Duration is not null)
                        {
                            <span class="duration">@_analysisResult.Duration</span>
                        }
                    </div>

                    @if (_analysisResult.Status == "Succeeded" && _analysisResult.Fields.Count > 0)
                    {
                        <table class="fields-table">
                            <thead><tr><th>Field</th><th>Value</th><th>Confidence</th></tr></thead>
                            <tbody>
                                @foreach (var f in _analysisResult.Fields)
                                {
                                    <tr>
                                        <td class="field-name">@f.Name</td>
                                        <td>@(f.Value ?? "—")</td>
                                        <td class="field-confidence">@(f.Confidence?.ToString("P0") ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else if (!string.IsNullOrEmpty(_analysisResult.ErrorMessage))
                    {
                        <div class="error-box"><pre>@_analysisResult.ErrorMessage</pre></div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private AnalyzerListPanel _listPanel = default!;

    // Detail panel
    private string? _selectedId;
    private string? _selectedDefinition;
    private bool _isLoadingDef;
    private bool _isEditing;
    private bool _isSaving;
    private string _editJson = "";
    private string? _message;
    private bool _isError;

    // Re-analyze
    private bool _isDragOver;
    private IBrowserFile? _testFile;
    private byte[]? _testFileBytes;
    private bool _isAnalyzing;
    private AnalysisViewModel? _analysisResult;

    private async Task SelectAnalyzer(string id)
    {
        _selectedId = id;
        _isEditing = false;
        _message = null;
        _isLoadingDef = true;
        _analysisResult = null;
        StateHasChanged();

        _selectedDefinition = await CuService.GetAnalyzerDefinitionAsync(id);
        _isLoadingDef = false;
    }

    private void StartEdit()
    {
        _editJson = _selectedDefinition ?? "";
        _isEditing = true;
        _message = null;
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _message = null;
    }

    private async Task SaveEdit()
    {
        _isSaving = true;
        _message = null;
        StateHasChanged();

        var (success, error) = await CuService.CreateOrUpdateAnalyzerAsync(_editJson, allowReplace: true);
        _isSaving = false;

        if (success)
        {
            _message = "Analyzer updated — try re-analyzing your test document below to verify.";
            _isError = false;
            _isEditing = false;
            _selectedDefinition = await CuService.GetAnalyzerDefinitionAsync(_selectedId!);
        }
        else
        {
            _message = error;
            _isError = true;
        }
    }

    private async Task OnTestFileSelected(InputFileChangeEventArgs e)
    {
        _testFile = e.File;
        _isDragOver = false;
        _analysisResult = null;
        await using var stream = _testFile.OpenReadStream(50 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _testFileBytes = ms.ToArray();
    }

    private async Task RunReAnalysis()
    {
        if (_testFile is null || _testFileBytes is null || _selectedId is null) return;
        _isAnalyzing = true;
        _analysisResult = null;
        StateHasChanged();

        using var stream = new MemoryStream(_testFileBytes);
        _analysisResult = await CuService.AnalyzeFileAsync(_selectedId, stream, _testFile.Name, _testFile.ContentType);
        _isAnalyzing = false;
    }
}
