    private async Task OnVDocFileSelected(InputFileChangeEventArgs e, int slotIndex)
    {
        if (slotIndex < 0 || slotIndex >= _vDocSlots.Count) return;
        _vDragOver = -1;
        var file = e.File;
        var maxSize = Options.Value.MaxFileSizeMB * 1024L * 1024L;
        await using var stream = file.OpenReadStream(maxSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        _vDocSlots[slotIndex] = new VDocSlot { File = file, Bytes = ms.ToArray() };
        _nDocResult = null;
    }

    private void AddVDocSlot() => _vDocSlots.Add(new());

    private void RemoveVDocSlot(int index)
    {
        if (index >= 0 && index < _vDocSlots.Count && _vDocSlots.Count > 2)
        {
            _vDocSlots.RemoveAt(index);
            _nDocResult = null;
        }
    }

    private string GetVDocTab(string label) => _vDocTabs.TryGetValue(label, out var tab) ? tab : "fields";
    private void SetVDocTab(string label, string tab) => _vDocTabs[label] = tab;

    private async Task RunValidation()
    {
        var activeSlots = _vDocSlots.Where(s => s.File is not null && s.Bytes is not null).ToList();
        if (activeSlots.Count < 2) return;

        _nDocResult = null;
        _isValidating = true;
        _vCompletedCount = 0;
        _vDocTabs = [];
        StateHasChanged();

        var results = new AnalysisViewModel[activeSlots.Count];
        var semaphore = new SemaphoreSlim(3);

        var tasks = activeSlots.Select(async (slot, idx) =>
        {
            await semaphore.WaitAsync();
            try
            {
                results[idx] = await VAnalyzeDocAsync(slot.Bytes!, slot.File!.Name, slot.File.ContentType);
                Interlocked.Increment(ref _vCompletedCount);
                await InvokeAsync(StateHasChanged);
            }
            finally { semaphore.Release(); }
        });

        await Task.WhenAll(tasks);

        _nDocResult = new NDocValidationViewModel { DocResults = results.ToList() };
        BuildFieldMatrix();
        _isValidating = false;
    }

    private async Task<AnalysisViewModel> VAnalyzeDocAsync(byte[] fileBytes, string fileName, string contentType)
    {
        try
        {
            using var s = new MemoryStream(fileBytes);
            return await CuService.AnalyzeFileAsync(_vAnalyzerId, s, fileName, contentType);
        }
        catch (Exception ex)
        {
            return new AnalysisViewModel { AnalyzerId = _vAnalyzerId, FileName = fileName, Status = "Failed", ErrorMessage = ex.Message };
        }
    }

    private void BuildFieldMatrix()
    {
        if (_nDocResult is null) return;
        var docCount = _nDocResult.DocResults.Count;
        var allFieldsByKey = new Dictionary<string, (string DisplayName, List<(int DocIndex, ExtractedField Field)> Entries)>(StringComparer.OrdinalIgnoreCase);

        for (int i = 0; i < docCount; i++)
        {
            var doc = _nDocResult.DocResults[i];
            if (doc.Status != "Succeeded") continue;
            var flat = VFlattenFields(doc.Fields);
            foreach (var field in flat)
            {
                var key = FieldNameNormalizer.NormalizeKey(field.Name);
                if (!allFieldsByKey.ContainsKey(key))
                    allFieldsByKey[key] = (field.Name, []);
                allFieldsByKey[key].Entries.Add((i, field));
            }
        }

        _nDocResult.FieldMatrix = allFieldsByKey
            .OrderBy(kvp => kvp.Value.DisplayName)
            .Select(kvp =>
            {
                var values = new List<string?>(new string?[docCount]);
                var confidences = new List<double?>(new double?[docCount]);
                foreach (var (docIdx, field) in kvp.Value.Entries)
                {
                    values[docIdx] = field.Value;
                    confidences[docIdx] = field.Confidence;
                }
                var nonNull = values.Where(v => v is not null).ToList();
                var consensus = nonNull.GroupBy(v => v!.Trim(), StringComparer.OrdinalIgnoreCase)
                    .OrderByDescending(g => g.Count()).FirstOrDefault()?.Key;
                var isConsistent = nonNull.Count > 0 && nonNull.All(v => string.Equals(v?.Trim(), consensus?.Trim(), StringComparison.OrdinalIgnoreCase));
                return new MatrixFieldRow { FieldName = kvp.Value.DisplayName, Values = values, Confidences = confidences, ConsensusValue = consensus, IsConsistent = isConsistent };
            })
            .OrderBy(r => r.IsConsistent ? 1 : 0)
            .ThenBy(r => r.FieldName)
            .ToList();
    }

    private static List<ExtractedField> VFlattenFields(List<ExtractedField> fields)
    {
        var result = new List<ExtractedField>();
        foreach (var field in fields)
        {
            if (field.Value is not null && field.Value.TrimStart().StartsWith('['))
                if (VTryFlattenJsonArray(field.Name, field.Value, result)) continue;
            if (field.Value is not null && field.Value.TrimStart().StartsWith('{'))
                if (VTryFlattenJsonObject(field.Name, field.Value, result)) continue;
            result.Add(field);
        }
        return result;
    }

    private static bool VTryFlattenJsonArray(string prefix, string json, List<ExtractedField> result)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != JsonValueKind.Array) return false;
            int index = 0;
            foreach (var item in doc.RootElement.EnumerateArray())
            {
                if (item.ValueKind == JsonValueKind.Object)
                    foreach (var prop in item.EnumerateObject())
                        result.Add(new ExtractedField { Name = $"{prefix}[{index}].{prop.Name}", Value = prop.Value.ValueKind == JsonValueKind.String ? prop.Value.GetString() : prop.Value.ToString() });
                else
                    result.Add(new ExtractedField { Name = $"{prefix}[{index}]", Value = item.ToString() });
                index++;
            }
            return index > 0;
        }
        catch { return false; }
    }

    private static bool VTryFlattenJsonObject(string prefix, string json, List<ExtractedField> result)
    {
        try
        {
            using var doc = JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != JsonValueKind.Object) return false;
            int count = 0;
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                result.Add(new ExtractedField { Name = $"{prefix}.{prop.Name}", Value = prop.Value.ValueKind == JsonValueKind.String ? prop.Value.GetString() : prop.Value.ToString() });
                count++;
            }
            return count > 0;
        }
        catch { return false; }
    }

    private static string VFormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private static string VGetConfidenceClass(double? confidence) =>
        confidence switch
        {
            >= 0.80 => "confidence-high",
            >= 0.60 => "confidence-mid",
            not null => "confidence-low",
            _ => ""
        };

